# ─────────────────────────────────────────────
#  CAPTANOVA — Environment Variables
#  Rename this file to .env.local and fill in
#  your real credentials before deploying.
# ─────────────────────────────────────────────

# Razorpay Payment Link (paste your full link)
RAZORPAY_PAYMENT_LINK=https://rzp.io/l/your-link-here

# Resend API Key (https://resend.com)
RESEND_API_KEY=re_your_key_here

# Admin email — receives lead notifications
ADMIN_EMAIL=you@yourdomain.com

# From address for outgoing emails (must be verified in Resend)
FROM_EMAIL=noreply@yourdomain.com

# Webhook secret for verifying Razorpay webhooks
WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Google Sheets integration
# GOOGLE_SHEETS_ID=your_sheet_id
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
